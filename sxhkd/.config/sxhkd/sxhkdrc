#    setxkbmap -query | grep -q 'ua' && setxkbmap us || setxkbmap ua,us

super + shift + z
    pavucontrol

XF86Launch1
    ~/scripts/dunst_mic_toggle.sh

super + m
    telegram-desktop

super + r
    ~/.config/rofi/launchers/type-1/launcher.sh 

super  + b
    firefox

super + t
    alacritty

super + e
    dolphin

Print
    spectacle -bc

super + l
    slock

super + p
    xrandr.sh

XF86PowerOff
    powermenu.sh

XF86AudioMute
    amixer -D pulse sset Master toggle

{XF86AudioRaiseVolume,XF86AudioLowerVolume}
    dunst_volume.sh {inc,dec} 5

super + {XF86AudioRaiseVolume,XF86AudioLowerVolume}
    dunst_mic.sh {inc,dec} 5
    #pamixer -u{d,i} 5 & polybar-msg action pulseaudio hook 0

{XF86MonBrightnessUp,XF86MonBrightnessDown}
    xbacklight {-inc,-dec} 10

# bspwm hotkeys

# make sxhkd reload its configuration files:
super + Escape
        pkill -USR1 -x sxhkd

# make polybar reload its configuration files:
super + shift + p
        pkill -USR1 -x polybar

# close and kill
super + {q}
        bspc node -c

# quit/restart bspwm
super + shift + {q,r}
        bspc {quit,wm -r}

# switch to floating/tiled
super + shift + {f,t}
        bspc node -t {floating,tiled}

# focus or send to the given desktop
super + {_,shift + }{1-9,0}
        bspc {desktop -f,node -d} '^{1-9,10}'



